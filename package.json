{
  "name": "hallstatt-apps",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --host=0.0.0.0 --port=3000",
    "build": "npm run build:home && npm run build --workspaces --if-present",
    "build:home": "vite build --outDir dist/home",
    "start": "node server.mjs",
    "preview": "npm run build && npm start",
    "lint": "tsc --noEmit && npm run lint --workspaces --if-present"
  },
  "workspaces": [
    "apps/pricing-sticker",
    "apps/product-description",
    "apps/review-generator",
    "apps/pricing-calculator"
  ],
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "lucide-react": "^0.546.0",
    "multer": "^2.1.1",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.15.1",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/multer": "^1.4.13",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "~5.8.2"
  }
}
