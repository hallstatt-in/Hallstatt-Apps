# Used by the backend server in local/dev or Railway.

# OPENAI_MODEL: Optional recovery model via OpenRouter if route models are unavailable.
OPENAI_MODEL="openai/gpt-4o-mini"

# OPENROUTER_API_KEYS: Preferred. Add one or more keys separated by commas or new lines.
# OPENROUTER_API_KEYS="key1,key2,key3"

# OPENROUTER_API_KEY: Optional single-key fallback.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# OPENROUTER_MODEL: Optional model slug from OpenRouter.
# Example: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet
OPENROUTER_MODEL="openai/gpt-4o-mini"

# OPENROUTER_FALLBACK_MODELS: Optional comma-separated fallback model slugs.
# OpenRouter allows up to 3 route entries total (primary model + up to 2 fallbacks).
OPENROUTER_FALLBACK_MODELS="qwen/qwen-2.5-7b-instruct:free,mistralai/mistral-7b-instruct:free"

# OPENROUTER_SITE_URL: Optional. Sent as HTTP-Referer header for OpenRouter analytics/ranking.
OPENROUTER_SITE_URL="http://localhost:3001"

# OPENROUTER_SITE_NAME: Optional. Sent as X-Title header.
OPENROUTER_SITE_NAME="ProductCopy AI"

# APP_URL: Optional fallback URL for hosted environments.
APP_URL="MY_APP_URL"

# PORT: Optional local server port. Railway injects this automatically.
PORT="3001"
